# Lambda の環境変数テンプレート（値は入れない）。
# LINE トークンと USER_ID は env ではなく SSM Parameter Store SecureString に置き、
# Lambda 実行時に LINE_TOKEN_PARAM / LINE_USER_ID_PARAM のパラメータ名から読む。
# ローカル実値は ~/.secrets/aws-whatsnew-agent.env（正本は ~/.secrets/line-notify.env）。

# 要約モデル（既定 amazon.nova-micro-v1:0）
BEDROCK_MODEL_ID=
# DynamoDB テーブル名（既定 aws-whatsnew-agent-sent）
TABLE_NAME=
# LINE シークレットの SSM パラメータ名（値ではなく名前）
LINE_TOKEN_PARAM=
LINE_USER_ID_PARAM=
# 初回だけ true にして既存記事を既読化（暴発防止）。通常運用は false
SEED_MODE=
# What's New RSS の URL
RSS_URL=
# 1メッセージあたりの最大記事数（既定 10）
MAX_ARTICLES_PER_MESSAGE=
# 除外サービス名のカンマ区切り（Phase1 は空＝全通過）
EXCLUDE_SERVICES=
